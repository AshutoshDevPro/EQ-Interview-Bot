# Application environment
PORT=5000
SESSION_SECRET=change-this-secret
PYTHON_AI_URL=http://python:8000
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Firebase config
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional database URL for sessions and analytics
# DATABASE_URL=postgres://username:password@host:5432/database

# Optional Python AI model configuration
# YOLO_MODEL_PATH=/app/yolov8n-face.pt
# EMOTION_MODEL_PATH=/app/emotion_model.h5
# TRACKER_TTL_SECONDS=120
